{
    "core": {
        "rest_port": 8123,
        "ws_port": 8124,
        "host": "127.0.0.1"
    },
    "pipeline": {
        "batch_window_ms": 50,
        "stt_model": "small",
        "tts_engine": "Qwen3-TTS",
        "llm_backend": "CPU",
        "context_length": 4096,
        "temperature": 0.7,
        "max_tokens": 512
    },
    "neural": {
        "emotion_net_enabled": true,
        "router_classifier_enabled": true
    },
    "memory": {
        "backend": "Redis",
        "collection": "revia_memories",
        "max_results": 5,
        "auto_store": true
    },
    "integrations": {
        "discord": {
            "enabled": false,
            "bot_token_env": "REVIA_DISCORD_BOT_TOKEN",
            "channel_ids": [],
            "guild_ids": [],
            "prefix": "!",
            "mention_only": false,
            "typing_delay_ms": [600, 1800]
        },
        "twitch": {
            "enabled": false,
            "oauth_token_env": "REVIA_TWITCH_OAUTH_TOKEN",
            "channels": [],
            "prefix": "!",
            "command": "revia",
            "respond_to_all": false,
            "max_response_len": 450,
            "user_cooldown_s": 8,
            "cache_ttl_s": 300
        }
    },
    "theme": "dark"
}
