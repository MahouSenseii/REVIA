{
    "core": {
        "rest_port": 8123,
        "ws_port": 8124,
        "host": "127.0.0.1"
    },
    "pipeline": {
        "batch_window_ms": 200,
        "stt_model": "small",
        "tts_engine": "Qwen3-TTS",
        "llm_backend": "CPU",
        "context_length": 4096,
        "temperature": 0.7,
        "max_tokens": 512
    },
    "neural": {
        "emotion_net_enabled": true,
        "router_classifier_enabled": true
    },
    "memory": {
        "backend": "ChromaDB",
        "collection": "revia_memories",
        "max_results": 5,
        "auto_store": true
    },
    "theme": "dark"
}
